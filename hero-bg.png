<hr data-start="668" data-end="671">
<h3 data-start="673" data-end="688">Setelah itu</h3>
<ol data-start="689" data-end="780">
<li data-start="689" data-end="708">
<p data-start="692" data-end="708">Commit changes</p>
</li>
<li data-start="709" data-end="728">
<p data-start="712" data-end="728">tunggu 5 detik</p>
</li>
<li data-start="729" data-end="753">
<p data-start="732" data-end="753">tekan <strong data-start="738" data-end="751">Ctrl + F5</strong></p>
</li>
<li data-start="754" data-end="780">
<p data-start="757" data-end="780">buka lagi cocoffeo.id</p>
</li>
</ol>
<p data-start="782" data-end="809">Background langsung muncul.</p>
<p data-start="811" data-end="847">Kalau masih belum muncul, saya akan:</p>
<ul data-start="848" data-end="909">
<li data-start="848" data-end="865">
<p data-start="850" data-end="865">cek ukuran hero</p>
</li>
<li data-start="866" data-end="879">
<p data-start="868" data-end="879">cek z-index</p>
</li>
<li data-start="880" data-end="909">
<p data-start="882" data-end="909">pakai fallback background</p>
